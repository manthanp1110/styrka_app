          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "package": "com.manthanp_2811.styrka"
    },
    "extra": {
      "eas": {
        "projectId": "714587b8-0d06-4ade-8c04-6df9c49db5ea"
      }
    },
    "owner": "manthanp_2811"
  }
